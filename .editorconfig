root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.go]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[{go.mod,go.sum}]
indent_style = tab

[*.toml]
indent_style = space
indent_size = 2

[*.pkl]
indent_style = space
indent_size = 2
